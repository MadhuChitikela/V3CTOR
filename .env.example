# ==========================================
# V3CTOR Backend - SMTP Configuration Template
# ==========================================
# Rename this file to '.env' and fill in your details to enable live email delivery.

# Server Configuration
PORT=3000

# Admin Notifications
# Email address where you want to receive notifications when a user submits the form.
ADMIN_EMAIL=vertexproject.in@gmail.com

# SMTP Server Configurations
# Example for Gmail SMTP: smtp.gmail.com
# Example for Outlook SMTP: smtp.office365.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Auth Credentials
# Gmail requires using an "App Password" rather than your account password.
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Admin Dashboard Credentials
# Choose a strong password to protect the /admin submissions console.
ADMIN_PASSWORD=

